{
    "toast_notification": {
        "type": "screen",
        "layer": 99,
        "should_steal_mouse": false,
        "render_game_backend": true,
        "animate_restart": false,
        "variables": [],
        "property_bag": {
            "toast_item": "air",
            "toast_title": "",
            "toast_subtitle": "",
            "toast_visible": false,
            "toast_timer": 0
        },
        "controls": [
            {
                "toast_panel": {
                    "type": "panel",
                    "size": [200, 50],
                    "offset": [0, -80],
                    "anchor_from": "top_center",
                    "anchor_to": "top_center",
                    "property_bag": {
                        "alpha": 1.0
                    },
                    "controls": [
                        {
                            "toast_bg": {
                                "type": "image",
                                "texture": "textures/ui/toast_background",
                                "size": [200, 50],
                                "offset": [0, 0],
                                "tiled": true
                            }
                        },
                        {
                            "toast_item_container": {
                                "type": "panel",
                                "size": [40, 40],
                                "offset": [10, 5],
                                "anchor_from": "left_middle",
                                "anchor_to": "left_middle",
                                "controls": [
                                    {
                                        "toast_item_renderer": {
                                            "type": "image",
                                            "size": [32, 32],
                                            "offset": [4, 4],
                                            "renderer": "inventory_item_renderer"
                                        }
                                    }
                                ]
                            }
                        },
                        {
                            "toast_text_panel": {
                                "type": "panel",
                                "size": [140, 40],
                                "offset": [55, 5],
                                "anchor_from": "left_middle",
                                "anchor_to": "left_middle",
                                "controls": [
                                    {
                                        "toast_title": {
                                            "type": "text",
                                            "offset": [0, 0],
                                            "text": "@toast_title",
                                            "color": [255, 255, 255, 255],
                                            "font_type": "MinecraftTen",
                                            "localization": false
                                        }
                                    },
                                    {
                                        "toast_subtitle": {
                                            "type": "text",
                                            "offset": [0, 18],
                                            "text": "@toast_subtitle",
                                            "color": [180, 180, 180, 255],
                                            "font_type": "MinecraftTen",
                                            "localization": false
                                        }
                                    }
                                ]
                            }
                        }
                    ],
                    "animations": [
                        {
                            "toast_show": {
                                "property_bag.alpha": 1.0,
                                "offset": [0, -80],
                                "easing": "outBounce",
                                "duration": 0.5
                            }
                        },
                        {
                            "toast_hide": {
                                "property_bag.alpha": 0.0,
                                "offset": [0, -200],
                                "easing": "inQuad",
                                "duration": 0.3
                            }
                        }
                    ]
                }
            }
        ]
    }
}