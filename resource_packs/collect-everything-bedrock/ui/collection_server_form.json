{
  "namespace": "collect_everything",

  "collection_browser_screen": {
    "type": "panel",
    "size": ["100%", "100%"],
    "controls": [{ "collection_browser_modal@collect_everything.collection_browser_modal": {} }],
    "bindings": [
      { "binding_name": "#title_text" },
      {
        "binding_type": "view",
        // only show when special data header is sent on the title
        "source_property_name": "(not ((#title_text - $collect_everything_data_prefix) = #title_text))",
        "target_property_name": "#visible"
      }
    ]
  },

  "collection_browser_modal": {
    "type": "stack_panel",
    "orientation": "vertical",
    "anims": [],
    "size": [325, 177],
    "layer": 15,
    "controls": [{ "top_panel@collect_everything.top_panel": {} }, { "main_panel@collect_everything.main_panel": {} }]
  },

  "top_panel": {
    "type": "panel",
    "size": [325, 20],
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "controls": [
      { "category_buttons@collect_everything.category_buttons": {} },
      { "top_right_panel@collect_everything.top_right_panel": {} }
    ]
  },

  "button_highlight_dark_background_white_foreground": {
    "type": "custom",
    "renderer": "gradient_renderer",
    "color1": [0.58, 0.58, 0.58, 1],
    "color2": [0.58, 0.58, 0.58, 1],
    "size": ["100%", "100%"]
  },

  "tooltip@common.hover_text": {
    // TODO: THIS DOES NOT WORK AT ALL RIGHT NOW... NEED TO FIGURE OUT HOW TO FIX IT
    // for accessibility and discoverability
  },

  "toolbar_button@common.button": {
    "$pressed_button_name": "button.form_button_click",
    "$icon_control|default": "settings_icon",
    "$tooltip_text|default": "",
    "size": [15, 15],
    "offset": [0, -5],
    "layer": 2,
    "default_control": "default_button",
    "hover_control": "hover_button",
    "pressed_control": "pressed_button",
    "anchor_from": "center",
    "anchor_to": "center",
    "bindings": [
      {
        "binding_name": "#null",
        "binding_type": "collection",
        "binding_condition": "none",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_name": "#null",
        "binding_type": "collection_details",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_name": "#form_button_text",
        "binding_type": "collection",
        "binding_collection_name": "form_buttons"
      }
    ],
    "controls": [
      {
        "default_button": {
          "type": "panel",
          "controls": [{ "icon@collect_everything.$icon_control": {} }]
        }
      },
      {
        "hover_button": {
          "type": "panel",
          "controls": [
            { "highlight@collect_everything.button_highlight_dark_background_white_foreground": {} },
            { "icon@collect_everything.$icon_control": {} },
            { "tooltip@collect_everything.tooltip": { "$tooltip_text": "($tooltip_text)" } }
          ]
        }
      },
      {
        "pressed_button": {
          "type": "panel",
          "controls": [
            { "highlight@collect_everything.button_highlight_dark_background_white_foreground": {} },
            { "icon@collect_everything.$icon_control": {} }
          ]
        }
      }
    ]
  },

  "settings_icon": {
    "type": "image",
    "texture": "textures/ui/settings",
    "size": [8, 6]
  },

  "help_icon": {
    "type": "label",
    "text": "?",
    "size": [6, 10]
  },

  "search_icon": {
    "type": "image",
    "texture": "textures/ui/search",
    "size": [8, 8]
  },

  "recent_icon": {
    "type": "image",
    "texture": "textures/ui/recent",
    "size": [9, 9]
  },

  "top_right_panel": {
    "type": "image",
    "texture": "textures/ui/TabTopBackRightMostDark",
    "size": [85, 24],
    "offset": [-2, 0],
    "anchor_from": "top_right",
    "anchor_to": "top_right",
    "layer": 0,
    "controls": [
      {
        "top_right_buttons": {
          "type": "stack_panel",
          "anchor_from": "top_right",
          "anchor_to": "top_right",
          "offset": [-5, 4],
          "orientation": "horizontal",
          "collection_name": "form_buttons",
          "controls": [
            // IMPORTANT: these hardcoded indexes need
            // to stay in sync with button insertion order
            // from script side
            {
              "search_button@collect_everything.toolbar_button": {
                "$icon_control": "search_icon",
                "$tooltip_text": "Search",
                "collection_index": 10
              }
            },
            {
              "recent_button@collect_everything.toolbar_button": {
                "$icon_control": "recent_icon",
                "$tooltip_text": "Recent",
                "collection_index": 11
              }
            },
            {
              "settings_button@collect_everything.toolbar_button": {
                "$icon_control": "settings_icon",
                "$tooltip_text": "Settings",
                "collection_index": 12
              }
            },
            {
              "help_button@collect_everything.toolbar_button": {
                "$icon_control": "help_icon",
                "$tooltip_text": "Help",
                "collection_index": 13
              }
            },
            {
              "close_button@common.light_close_button": { "size": [15, 15] }
            }
          ]
        }
      }
    ]
  },

  "modal_title": {
    "type": "label",
    "text": "#display_text",
    "color": "$title_text_color",
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "offset": [0, -1],
    "bindings": [
      {
        "binding_type": "view",
        // remove data header from title string
        "source_property_name": "(#title_text - ('%.129s' * #title_text))",
        "target_property_name": "#display_text"
      }
    ]
  },

  "category_buttons": {
    "type": "stack_panel",
    "orientation": "horizontal",
    "size": ["100%c", "100%c"],
    "offset": [2, -1],
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "layer": 1,
    "collection_name": "form_buttons",
    "controls": [
      // IMPORTANT: these use hard-coded indexes; we need to make sure these
      // stay in sync with the order they are added to the buttons array
      // on the script side
      { "all_tab@collect_everything.inventory_slot_tab": { "collection_index": 0 } },
      { "items_tab@collect_everything.inventory_slot_tab": { "collection_index": 1 } },
      { "biomes_tab@collect_everything.inventory_slot_tab": { "collection_index": 2 } },
      { "entities_tab@collect_everything.inventory_slot_tab": { "collection_index": 3 } },
      { "effects_tab@collect_everything.inventory_slot_tab": { "collection_index": 4 } },
      { "enchantments_tab@collect_everything.inventory_slot_tab": { "collection_index": 5 } },
      { "unobtainables_tab@collect_everything.inventory_slot_tab": { "collection_index": 6 } },
      { "deaths_tab@collect_everything.inventory_slot_tab": { "collection_index": 7 } }
    ]
  },

  "inventory_slot_tab@common.button": {
    "$pressed_button_name": "button.form_button_click",
    "size": [24, 26],
    "default_control": "inventory_tab_default_view",
    "hover_control": "inventory_tab_hover_view",
    "pressed_control": "inventory_tab_pressed_view",
    "bindings": [
      {
        "binding_name": "#null",
        "binding_type": "collection",
        "binding_condition": "none",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_name": "#null",
        "binding_type": "collection_details",
        "binding_collection_name": "form_buttons"
      }
    ],
    "controls": [
      { "inventory_tab_default_view@collect_everything.inventory_slot_tab_default": {} },
      { "inventory_tab_hover_view@collect_everything.inventory_slot_tab_hover": { "$hover": true } },
      { "inventory_tab_pressed_view@collect_everything.inventory_slot_tab_hover": { "$pressed": true } }
    ]
  },

  "inventory_slot_tab_default": {
    "type": "panel",
    "size": ["100%", "100%"],
    "bindings": [
      {
        "binding_name": "#null",
        "binding_type": "collection",
        "binding_condition": "none",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_name": "#null",
        "binding_type": "collection_details",
        "binding_collection_name": "form_buttons"
      }
    ],
    "controls": [
      {
        "inventory_slot_tab_inactive@collect_everything.inventory_slot_tab_inactive": {
          "bindings": [
            {
              "binding_name": "#null",
              "binding_type": "collection",
              "binding_condition": "none",
              "binding_collection_name": "form_buttons"
            },
            {
              "binding_name": "#null",
              "binding_type": "collection_details",
              "binding_collection_name": "form_buttons"
            },
            {
              "binding_type": "view",
              // binding to activeIndex: (#collection_index !== activeIndex)
              "source_property_name": "(not (#collection_index = (('%.35s' * #title_text) - ('%.33s' * #title_text) * 1)))",
              "target_property_name": "#visible"
            }
          ]
        }
      },
      {
        "inventory_slot_tab_active@collect_everything.inventory_slot_tab_active": {
          "bindings": [
            {
              "binding_name": "#null",
              "binding_type": "collection",
              "binding_condition": "none",
              "binding_collection_name": "form_buttons"
            },
            {
              "binding_name": "#null",
              "binding_type": "collection_details",
              "binding_collection_name": "form_buttons"
            },
            {
              "binding_type": "view",
              // binding to activeIndex: (#collection_index === activeIndex)
              // for some reason this only works if we don't multiply by 1
              "source_property_name": "(#collection_index = (('%.35s' * #title_text) - ('%.33s' * #title_text)))",
              "target_property_name": "#visible"
            }
          ]
        }
      }
    ]
  },

  "inventory_slot_tab_active": {
    "type": "image",
    "texture": "textures/ui/TabTopFront",
    "size": ["100%", "100%"],
    "$hover|default": false,
    "$pressed|default": false,
    "controls": [{ "item@collect_everything.inventory_item": { "offset": [0, -1] } }]
  },

  "inventory_slot_tab_inactive": {
    "type": "image",
    "texture": "textures/ui/TabTopBack",
    "size": ["100%", "100%"],
    "$hover|default": false,
    "$pressed|default": false,
    "controls": [{ "item@collect_everything.inventory_item": { "offset": [0, -1] } }]
  },

  "inventory_slot_tab_hover": {
    "type": "image",
    "texture": "textures/ui/TabTopFrontHover",
    "size": ["100%", "100%"],
    "$hover|default": false,
    "$pressed|default": false,
    "controls": [{ "item@collect_everything.inventory_item": { "offset": [0, -1] } }]
  },

  "main_panel": {
    "type": "image",
    "texture": "textures/ui/dialog_background_opaque",
    "size": ["100%", "100%"],
    "layer": 0,
    "controls": [
      {
        "main_contents": {
          "type": "panel",
          "size": [325, 177],
          "offset": [6, 9],
          "anchor_from": "top_left",
          "anchor_to": "top_left",
          "controls": [
            { "modal_title@collect_everything.modal_title": {} },
            {
              "toggle_wrapper": {
                "type": "stack_panel",
                "orientation": "horizontal",
                "collection_name": "form_buttons",
                "anchor_from": "top_right",
                "anchor_to": "top_right",
                "size": [105, 16],
                "offset": [-22, -5],
                "controls": [
                  {
                    "label_wrapper": {
                      "type": "panel",
                      "size": [80, 16],
                      "controls": [
                        {
                          "filter_label_all": {
                            "type": "label",
                            "text": "All",
                            "color": "$title_text_color",
                            "text_alignment": "right",
                            "size": [80, 8],
                            "anchor_from": "right_middle",
                            "anchor_to": "right_middle",
                            "bindings": [
                              {
                                "binding_type": "view",
                                "source_property_name": "((('%.42s' * #title_text) - ('%.41s' * #title_text)) = 0)",
                                "target_property_name": "#visible"
                              }
                            ]
                          }
                        },
                        {
                          "filter_label_uncollected": {
                            "type": "label",
                            "text": "Uncollected",
                            "color": "$title_text_color",
                            "text_alignment": "right",
                            "size": [80, 8],
                            "anchor_from": "right_middle",
                            "anchor_to": "right_middle",
                            "bindings": [
                              {
                                "binding_type": "view",
                                "source_property_name": "((('%.42s' * #title_text) - ('%.41s' * #title_text)) = 1)",
                                "target_property_name": "#visible"
                              }
                            ]
                          }
                        }
                      ]
                    }
                  },
                  { "gap": { "type": "panel", "size": [3, 0] } },
                  { "filter_toggle@collect_everything.toggle": { "collection_index": 14 } }
                ]
              }
            },
            { "@collect_everything.collection_browser_items_panel": {} }
          ]
        }
      }
    ]
  },

  "toggle@common.button": {
    "$pressed_button_name": "button.form_button_click",
    "$state|default": "§z0",
    "size": [30, 16],
    "offset": [0, -5],
    "layer": 2,
    "default_control": "default_button",
    "hover_control": "hover_button",
    "pressed_control": "pressed_button",
    "anchor_from": "center",
    "anchor_to": "center",
    "bindings": [
      {
        "binding_name": "#null",
        "binding_type": "collection",
        "binding_condition": "none",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_name": "#null",
        "binding_type": "collection_details",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_name": "#form_button_text",
        "binding_type": "collection",
        "binding_collection_name": "form_buttons"
      }
    ],
    "controls": [
      {
        "default_button": {
          "type": "panel",
          "controls": [
            {
              "off": {
                "type": "image",
                "texture": "textures/ui/toggle_off",
                "bindings": [
                  {
                    "binding_type": "view",
                    "source_property_name": "((('%.42s' * #title_text) - ('%.41s' * #title_text)) = 0)",
                    "target_property_name": "#visible"
                  }
                ]
              }
            },
            {
              "on": {
                "type": "image",
                "texture": "textures/ui/toggle_on",
                "bindings": [
                  {
                    "binding_type": "view",
                    "source_property_name": "((('%.42s' * #title_text) - ('%.41s' * #title_text)) = 1)",
                    "target_property_name": "#visible"
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "hover_button": {
          "type": "panel",
          "controls": [
            {
              "off": {
                "type": "image",
                "texture": "textures/ui/toggle_off_hover",
                "bindings": [
                  {
                    "binding_type": "view",
                    "source_property_name": "((('%.42s' * #title_text) - ('%.41s' * #title_text)) = 0)",
                    "target_property_name": "#visible"
                  }
                ]
              }
            },
            {
              "on": {
                "type": "image",
                "texture": "textures/ui/toggle_on_hover",
                "bindings": [
                  {
                    "binding_type": "view",
                    "source_property_name": "((('%.42s' * #title_text) - ('%.41s' * #title_text)) = 1)",
                    "target_property_name": "#visible"
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "pressed_button": {
          "type": "panel",
          "controls": [
            {
              "off": {
                "type": "image",
                "texture": "textures/ui/toggle_off_hover",
                "bindings": [
                  {
                    "binding_type": "view",
                    "source_property_name": "((('%.42s' * #title_text) - ('%.41s' * #title_text)) = 0)",
                    "target_property_name": "#visible"
                  }
                ]
              }
            },
            {
              "on": {
                "type": "image",
                "texture": "textures/ui/toggle_on_hover",
                "bindings": [
                  {
                    "binding_type": "view",
                    "source_property_name": "((('%.42s' * #title_text) - ('%.41s' * #title_text)) = 1)",
                    "target_property_name": "#visible"
                  }
                ]
              }
            }
          ]
        }
      }
    ]
  },

  "collection_browser_items_panel": {
    "type": "image",
    "texture": "textures/ui/dialog_inset_background",
    "offset": [0, 12],
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "size": [313, 150],
    "controls": [
      { "@collect_everything.collection_browser_grid_wrapper": {} },
      { "@collect_everything.collection_browser_pagination": {} },
      {
        "difficulty_labels": {
          "type": "stack_panel",
          "orientation": "horizontal",
          "size": ["100%c", "100%c"],
          "offset": [-3, 4],
          "anchor_from": "bottom_right",
          "anchor_to": "bottom_right",
          "layer": 20,
          "controls": [
            {
              "basic_difficulty_label@collect_everything.difficulty_label": {
                "$text": "Basic",
                "$value": 0
              }
            },
            {
              "committed_difficulty_label@collect_everything.difficulty_label": {
                "$text": "Committed",
                "$value": 1
              }
            },
            {
              "insane_difficulty_label@collect_everything.difficulty_label": {
                "$text": "Insane",
                "$value": 2
              }
            },
            {
              "difficulty": {
                "type": "label",
                "text": " difficulty"
              }
            }
          ]
        }
      }
    ]
  },

  "difficulty_label": {
    "type": "label",
    "$text|default": "",
    "$value|default": "",
    "text": "$text",
    "color": [1, 1, 1, 1],
    "anchor_from": "bottom_right",
    "anchor_to": "bottom_right",
    "text_alignment": "right",
    "bindings": [
      {
        "binding_type": "view",
        // we create all possible difficulty labels; only show this one if it matches the actual difficulty value
        "source_property_name": "((('%.56s' * #title_text) - ('%.55s' * #title_text)) = $value)",
        "target_property_name": "#visible"
      }
    ]
  },

  "collection_browser_pagination": {
    "type": "panel",
    "size": [55, 17],
    "offset": [0, -3],
    "anchor_from": "bottom_middle",
    "anchor_to": "bottom_middle",
    "controls": [
      {
        "previous_button@collect_everything.pagination_button": {
          "$texture_path_default": "textures/ui/page_previous",
          "$texture_path_active": "textures/ui/page_previous_active",
          "anchor_from": "left_middle",
          "anchor_to": "left_middle",
          "property_bag": {
            // IMPORTANT: these hardcoded indexes need
            // to stay in sync with button insertion order
            // from script side
            "#collection_index": 8,
            "#collection_name": "form_buttons"
          },
          "bindings": [
            {
              "binding_type": "view",
              "source_property_name": "((#title_text - '|hasPrevious|:0') = #title_text)",
              "target_property_name": "#visible"
            }
          ]
        }
      },
      { "page_label@collect_everything.page_label": {} },
      {
        "next_button@collect_everything.pagination_button": {
          "$texture_path_default": "textures/ui/page_next",
          "$texture_path_active": "textures/ui/page_next_active",
          "anchor_from": "right_middle",
          "anchor_to": "right_middle",
          "default_focus_precedence": 2,
          "property_bag": {
            // IMPORTANT: these hardcoded indexes need
            // to stay in sync with button insertion order
            // from script side
            "#collection_index": 9,
            "#collection_name": "form_buttons"
          },
          "bindings": [
            {
              "binding_type": "view",
              "source_property_name": "((#title_text - '|hasNext|:0') = #title_text)",
              "target_property_name": "#visible"
            }
          ]
        }
      }
    ]
  },

  "pagination_button_image": {
    "type": "image",
    "$texture_path|default": "",
    "texture": "$texture_path",
    "size": [11, 17],
    "layer": 10
  },

  "pagination_button@common.button": {
    "$pressed_button_name": "button.form_button_click",
    "$texture_path_default|default": "",
    "$texture_path_active|default": "",
    "size": [11, 17],
    "layer": 10,
    "default_control": "default",
    "hover_control": "hover",
    "pressed_control": "pressed",
    "controls": [
      { "default@collect_everything.pagination_button_image": { "$texture_path": "$texture_path_default" } },
      { "hover@collect_everything.pagination_button_image": { "$texture_path": "$texture_path_active" } },
      { "pressed@collect_everything.pagination_button_image": { "$texture_path": "$texture_path_active" } }
    ],
    "bindings": [
      {
        "binding_name": "#null",
        "binding_type": "collection",
        "binding_condition": "none",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_name": "#null",
        "binding_type": "collection_details",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_name": "#form_button_text",
        "binding_type": "collection",
        "binding_collection_name": "form_buttons"
      }
    ]
  },

  "page_label": {
    "type": "stack_panel",
    "orientation": "horizontal",
    "anchor_from": "center_middle",
    "anchor_to": "center_middle",
    "size": ["default", 7],
    "offset": [0, -1],
    "layer": 10,
    "controls": [
      {
        "page_number_label": {
          "type": "label",
          "text": "#page_number",
          "color": [1, 1, 1, 1],
          "layer": 10,
          "bindings": [
            {
              "binding_type": "view",
              // bind to pageNumber value
              "source_property_name": "(('§z') + (('%.114s' * #title_text) - ('%.112s' * #title_text)))",
              "target_property_name": "#page_number"
            }
          ]
        }
      },
      {
        "divider_label": {
          "type": "label",
          "text": "/",
          "color": [1, 1, 1, 1],
          "layer": 10
        }
      },
      {
        "total_pages_label": {
          "type": "label",
          "text": "#total_pages",
          "color": [1, 1, 1, 1],
          "layer": 10,
          "bindings": [
            {
              "binding_type": "view",
              // bind do totalPages value
              "source_property_name": "(('§z') + (('%.129s' * #title_text) - ('%.127s' * #title_text)))",
              "target_property_name": "#total_pages"
            }
          ]
        }
      }
    ]
  },

  "collection_browser_grid_wrapper": {
    "type": "panel",
    "size": [306, 126],
    "offset": [3, 3],
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "clips_children": true,
    "controls": [{ "grid@collect_everything.collection_browser_grid": { "size": [315, 134] } }]
  },

  "collection_browser_grid": {
    "type": "grid",
    "size": [306, 144],
    "min_size": [306, 144],
