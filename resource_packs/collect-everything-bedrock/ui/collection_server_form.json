  "collection_ui_template": {
    "type": "panel",
    "size": ["100%c", "100%c"],
    "bindings": [
      {
        "binding_name": "#title_text",
        "binding_type": "global"
      }
    ],
    "controls": [
      {
        "background": {
          "type": "image",
          "texture": "$border_and_background_texture",
          "layer": 0,
          "size": [323, 184],
          "controls": [
            {
              "container": {
                "type": "panel",
                "size": [313, 149],
                "offset": [5, 5],
                "anchor_from": "top_left",
                "anchor_to": "top_left",
                "controls": [
                  {
                    "stack": {
                      "type": "stack_panel",
                      "orientation": "vertical",
                      "size": [313, 144],
                      "controls": [
                        {
                          "gap@common.empty_panel": {
                            "size": ["100%", 5],
                            "controls": [
                              {
                                "close_button@common.close_button": {
                                  "$close_button_offset": [5, -5]
                                }
                              }
                            ]
                          }
                        },
                        {
                          "text@collection_ui.collection_label": {
                            "offset": [0, -5]
                          }
                        },
                        {
                          "top_row": {
                            "type": "stack_panel",
                            "orientation": "horizontal",
                            "size": [313, 18],
                            "offset": [0, -3],
                            "layer": 1,
                            "collection_name": "form_buttons",
                            "controls": [
                              { "i0@collection_ui.inventory_item_panel": { "collection_index": 0 } },
                              { "i1@collection_ui.inventory_item_panel": { "collection_index": 1 } },
                              { "i2@collection_ui.inventory_item_panel": { "collection_index": 2 } },
                              { "i3@collection_ui.inventory_item_panel": { "collection_index": 3 } },
                              { "i4@collection_ui.inventory_item_panel": { "collection_index": 4 } },
                              { "i5@collection_ui.inventory_item_panel": { "collection_index": 5 } },
                              { "i6@collection_ui.inventory_item_panel": { "collection_index": 6 } }
                            ]
                          }
                        },
                        {
                          "scroll_view@common.scrolling_panel": {
                            "$scrolling_content": "collection_ui.grid_items",
                            "$scrolling_pane_size": [313, 134],
                            "offset": [0, 2]
                          }
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      }
    ]
  },
  "collection_panel": {
    "type": "panel",
    "size": ["100%", "100%"],
    "controls": [
      {
        "@collection_ui.collection_ui_template": {
          "$grid_size": [17, 8],
          "$condition": "§c§o§l§l§e§c§t§i§o§n"
        }
      }
    ]
  },
  "inventory_item_panel": {
    "type": "panel",
    "size": [18, 18],
    "layer": 1,
    "bindings": [
      {
        "binding_name": "#null",
        "binding_type": "collection",
        "binding_condition": "none",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_name": "#null",
        "binding_type": "collection_details",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_name": "#form_button_text",
        "binding_type": "collection",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_name": "#null",
        "binding_type": "view",
        "source_property_name": "(not (#form_button_text = ''))",
        "target_property_name": "#visible"
      },
      {
        "binding_name": "#null",
        "binding_type": "view",
        "source_property_name": "(#form_button_text = '')",
        "target_property_name": "#ignored"
      }
    ],
    "controls": [
      {
        "bg@collection_ui.cell": {}
      },
      {
        "inventory_button_amount@collection_ui.inventory_button_amount": {}
      },
      {
        "inventory_item@collection_ui.inventory_item": {}
      }
    ]
  },
  "cell": {
    "type": "image",
    "texture": "textures/ui/item_background",
    "size": [18, 18],
    "layer": 2
  },
  "inventory_item@common.button": {
    "$pressed_button_name": "button.form_button_click",
    "bindings": [
      {
        "binding_name": "#null",
        "binding_type": "collection",
        "binding_condition": "none",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_name": "#null",
        "binding_type": "collection_details",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_name": "#form_button_text",
        "binding_type": "collection",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_name": "#null",
        "binding_type": "view",
        "source_property_name": "(not (#form_button_text = ''))",
        "target_property_name": "#visible"
      }
    ],
    "$aux_id": [
      {
        "binding_name": "#form_button_texture",
        "binding_type": "collection",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_type": "view",
        "source_property_name": "(not (('%.8s' * #form_button_texture) = 'textures'))",
        "target_property_name": "#visible"
      },
      {
        "binding_type": "view",
        "source_property_name": "(not ((#texture = '') or (#texture = 'loading')))",
        "target_property_name": "#visible"
      },
      {
        "binding_type": "view",
        "source_property_name": "((#form_button_texture - (#form_button_texture % 65536)) / 65536)",
        "target_property_name": "#item_id_aux"
      }
    ],
    "default_control": "default",
    "hover_control": "hover",
    "pressed_control": "pressed",
    "controls": [
      {
        "default@collection_ui.default_control": {}
      },
      {
        "hover@collection_ui.hover_control": {}
      },
      {
        "pressed@collection_ui.pressed_control": {}
      }
    ]
  },
  "default_control": {
    "type": "panel",
    "size": [16, 16],
    "controls": [
      {
        "item@beacon.item_renderer": {
          "size": [16, 16],
          "layer": 4,
          "bindings": "$aux_id"
        }
      },
      {
        "durability_bar@collection_ui.durability_bar": {}
      },
      {
        "non_renderer_item@collection_ui.non_renderer_item": {}
      }
    ]
  },
  "hover_control": {
    "type": "panel",
    "size": [18, 18],
    "controls": [
      {
        "item@beacon.item_renderer": {
          "size": [16, 16],
          "layer": 4,
          "bindings": "$aux_id",
          "offset": [1, 1]
        }
      },
      {
        "durability_bar@collection_ui.durability_bar": {
          "offset": [0, -2.5]
        }
      },
      {
        "non_renderer_item@collection_ui.non_renderer_item": {}
      },
      {
        "item_details@collection_ui.item_details": {}
      },
      {
        "highlight_slot@collection_ui.highlight_slot": {}
      },
      {
        "focus_border@collection_ui.focus_border": {}
      }
    ]
  },
  "pressed_control": {
    "type": "panel",
    "size": [16, 16],
    "controls": [
      {
        "item@beacon.item_renderer": {
          "size": [16, 16],
          "layer": 4,
          "bindings": "$aux_id"
        }
      },
      {
        "durability_bar@collection_ui.durability_bar": {}
      },
      {
        "non_renderer_item@collection_ui.non_renderer_item": {}
      },
      {
        "focus_border@collection_ui.focus_border": {}
      }
    ]
  },
  "highlight_slot": {
    "type": "image",
    "size": [18, 18],
    "texture": "textures/ui/highlight_slot",
    "layer": 3
  },
  "focus_border": {
    "type": "image",
    "size": [18, 18],
    "texture": "textures/ui/focus_border_white",
    "layer": 4
  },
  "item_details": {
    "type": "custom",
    "renderer": "hover_text_renderer",
    "allow_clipping": false,
    "layer": 30,
    "bindings": [
      {
        "binding_name": "#form_button_text",
        "binding_type": "collection",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_type": "view",
        "source_property_name": "(#form_button_text - ('%.14s' * #form_button_text))",
        "target_property_name": "#hover_text"
      },
      {
        "binding_type": "collection_details",
        "binding_collection_name": "form_buttons"
      }
    ]
  },
  "durability_bar": {
    "type": "image",
    "texture": "textures/ui/d_b",
    "size": [14, 2],
    "layer": 8,
    "anchor_from": "bottom_middle",
    "anchor_to": "bottom_middle",
    "offset": [0, -1.5],
    "bindings": [
      {
        "binding_type": "collection_details",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_name": "#form_button_text",
        "binding_type": "collection",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_type": "view",
        "source_property_name": "((#form_button_text - 'dur#00') = #form_button_text)",
        "target_property_name": "#visible"
      }
    ],
    "controls": [
      {
        "val": {
          "type": "image",
          "layer": 7,
          "texture": "textures/ui/d_g",
          "size": ["100%", "50%"],
          "offset": [0, -0.5],
          "clip_pixelperfect": false,
          "clip_direction": "left",
          "$clip_max": 99,
          "$one": 1.0,
          "bindings": [
            {
              "binding_type": "collection_details",
              "binding_collection_name": "form_buttons"
            },
            {
              "binding_name": "#form_button_text",
              "binding_type": "collection",
              "binding_collection_name": "form_buttons"
            },
            {
              "binding_type": "view",
              "source_property_name": "((%.14s * #form_button_text) - (%.12s * #form_button_text))",
              "target_property_name": "#ratio"
            },
            {
              "binding_type": "view",
              "source_property_name": "(#ratio * $one)",
