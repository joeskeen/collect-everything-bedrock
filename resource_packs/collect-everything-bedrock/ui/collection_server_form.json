{
  "namespace": "collect_everything",

  "collection_browser_screen": {
    "type": "screen",
    "size": ["100%", "100%"],
    "close_on_player_hurt": true,
    "bindings": [
      // {
      //   "binding_name": "$",
      //   "binding_type": "collection",
      //   "binding_collection_name": "form_array"
      // }
    ],
    "controls": [{ "collection_browser_modal@collection_browser_modal": {} }]
  },

  "collection_browser_modal": {
    "type": "stack_panel",
    "orientation": "vertical",
    "size": [316, 162],
    "controls": [{ "top_panel@top_panel": {} }, { "main_panel@main_panel": {} }]
  },

  "top_panel": {
    "type": "panel",
    "size": [315, 20],
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "controls": [{ "category_buttons@category_buttons": {} }, { "top_right_panel@top_right_panel": {} }]
  },

  "button_highlight_dark_background_white_foreground": {
    "type": "custom",
    "renderer": "gradient_renderer",
    "color1": [0.58, 0.58, 0.58, 1],
    "color2": [0.58, 0.58, 0.58, 1],
    "size": ["100%", "100%"]
  },

  "tooltip@common.hover_text": {
    // TODO: THIS DOES NOT WORK AT ALL RIGHT NOW... NEED TO FIGURE OUT HOW TO FIX IT
    // "$tooltip_text|default": "hello",
    // ""
    // "$hover_text_binding_name|default": "#hover_text",
    // "hover_text": "$tooltip_text",
    // "bindings": [
    //   // {
    //   //   "binding_name": "$hover_text_binding_name",
    //   //   "binding_name_override": "#hover_text",
    //   //   "binding_type": "collection",
    //   //   "binding_collection_name": "$item_collection_name"
    //   // },
    //   {
    //     "binding_name": "$tooltip_text",
    //     "binding_name_override": "#hover_text",
    //     "binding_type": "view"
    //   }
    //   // {
    //   //   "binding_type": "view",
    //   //   "source_property_name": "($tooltip_text = '')",
    //   //   "target_property_name": "#ignored"
    //   // }
    // ]
  },

  "toolbar_button@common.button": {
    "$pressed_button_name": "button.form_button_click",
    "$icon_control|default": "settings_icon",
    "$tooltip_text|default": "",
    "size": [15, 15],
    "offset": [0, -5],
    "layer": 2,
    "default_control": "default_button",
    "hover_control": "hover_button",
    "pressed_control": "pressed_button",
    "anchor_from": "center",
    "anchor_to": "center",
    "bindings": [
      {
        "binding_name": "#null",
        "binding_type": "collection",
        "binding_condition": "none",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_name": "#null",
        "binding_type": "collection_details",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_name": "#form_button_text",
        "binding_type": "collection",
        "binding_collection_name": "form_buttons"
      }
    ],
    "controls": [
      {
        "default_button": {
          "type": "panel",
          "controls": [{ "icon@$icon_control": {} }]
        }
      },
      {
        "hover_button": {
          "type": "panel",
          "controls": [
            { "highlight@button_highlight_dark_background_white_foreground": {} },
            { "icon@$icon_control": {} },
            { "tooltip@tooltip": { "$tooltip_text": "($tooltip_text)" } }
          ]
        }
      },
      {
        "pressed_button": {
          "type": "panel",
          "controls": [
            { "highlight@button_highlight_dark_background_white_foreground": {} },
            { "icon@$icon_control": {} }
          ]
        }
      }
    ]
  },
  "settings_icon": {
    "type": "image",
    "texture": "textures/ui/settings",
    "size": [8, 6]
  },
  "help_icon": {
    "type": "label",
    "text": "?",
    "size": [6, 10]
  },
  "search_icon": {
    "type": "image",
    "texture": "textures/ui/search",
    "size": [8, 8]
  },
  "recent_icon": {
    "type": "image",
    "texture": "textures/ui/recent",
    "size": [9, 9]
  },

  "top_right_panel": {
    "type": "image",
    "texture": "textures/ui/TabTopBackRightMostDark",
    "size": [85, 24],
    "anchor_from": "top_right",
    "anchor_to": "top_right",
    "layer": 0,
    "controls": [
      {
        "top_right_buttons": {
          "type": "stack_panel",
          "anchor_from": "top_right",
          "anchor_to": "top_right",
          "offset": [-5, 4],
          "orientation": "horizontal",
          "collection_name": "form_buttons",

          "controls": [
            {
              "search_button@toolbar_button": {
                "$icon_control": "search_icon",
                "$tooltip_text": "Search",
                "collection_index": 28
              }
            },
            {
              "recent_button@toolbar_button": {
                "$icon_control": "recent_icon",
                "$tooltip_text": "Recent",
                "collection_index": 29
              }
            },
            {
              "settings_button@toolbar_button": {
                "$icon_control": "settings_icon",
                "$tooltip_text": "Settings",
                "collection_index": 30
              }
            },
            {
              "help_button@toolbar_button": {
                "$icon_control": "help_icon",
                "$tooltip_text": "Help",
                "collection_index": 31
              }
            },
            {
              "close_button@common.light_close_button": { "size": [15, 15] }
            }
          ]
        }
      }
      // { "modal_title@modal_title": {} }
    ]
  },

  "modal_title": {
    "type": "label",
    "text": "#title_text",
    "color": "$title_text_color",
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "offset": [7, 7]
    // "layer": 2,
    // "anchor_from": "top_left",
    // "anchor_to": "top_left"
  },

  "category_buttons": {
    "type": "stack_panel",
    "orientation": "horizontal",
    "size": ["100%c", "100%c"],
    "offset": [2, -1],
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "layer": 1,
    "collection_name": "form_buttons",
    "bindings": [
      {
        "binding_name": "#form_button_length",
        "binding_name_override": "#length",
        "binding_condition": "once"
      },
      {
        "source_property_name": "(#length - $reserved_button_length)",
        "target_property_name": "#collection_index",
        "binding_type": "view"
      }
    ],
    "controls": [
      { "@inventory_slot_tab": { "collection_index": 0 } },
      { "@inventory_slot_tab": { "collection_index": 1 } },
      { "@inventory_slot_tab": { "collection_index": 2 } },
      { "@inventory_slot_tab": { "collection_index": 3 } },
      { "@inventory_slot_tab": { "collection_index": 4 } },
      { "@inventory_slot_tab": { "collection_index": 5 } },
      { "@inventory_slot_tab": { "collection_index": 6 } }
    ]
  },

  "inventory_slot_tab@common.button": {
    "$pressed_button_name": "button.form_button_click",
    "size": [24, 26],
    "bindings": [
      {
        "binding_name": "#null",
        "binding_type": "collection",
        "binding_condition": "none",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_name": "#null",
        "binding_type": "collection_details",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_name": "#form_button_text",
        "binding_type": "collection",
        "binding_collection_name": "form_buttons"
      }
    ],
    "default_control": "inventory_tab_default_view",
    "hover_control": "inventory_tab_hover_view",
    "pressed_control": "inventory_tab_pressed_view",
    "controls": [
      { "inventory_tab_default_view@inventory_slot_tab_default": {} },
      { "inventory_tab_hover_view@inventory_slot_tab_hover": { "$hover": true } },
      { "inventory_tab_pressed_view@inventory_slot_tab_hover": { "$pressed": true } }
    ]
  },

  "inventory_slot_tab_default": {
    "type": "image",
    "texture": "textures/ui/TabTopFront",
    "size": ["100%", "100%"],
    "$hover|default": false,
    "$pressed|default": false,
    "controls": [
      {
        "item@inventory_item": {
          "offset": [0, -1]
        }
      }
    ]
  },

  "inventory_slot_tab_hover": {
    "type": "image",
    "texture": "textures/ui/TabTopFrontHover",
    "size": ["100%", "100%"],
    "$hover|default": false,
    "$pressed|default": false,
    "controls": [
      {
        "item@inventory_item": {
          "offset": [0, -1]
        }
      }
    ]
  },

  "main_panel": {
    "type": "image",
    "texture": "textures/ui/dialog_background_opaque",
    "size": ["100%", "default"],
    "layer": 0,
    "controls": [
      {
        "main_contents": {
          "type": "stack_panel",
          "orientation": "vertical",
          "size": ["100%c", "default"],
          "offset": [6, 9],

          "anchor_from": "top_left",
          "anchor_to": "top_left",
          "controls": [
            { "modal_title@modal_title": {} },
            { "@gap": { "size": [0, 3] } },
            {
              "@common.scrolling_panel": {
                "$scrolling_content": "collect_everything.collection_browser_grid",
                "$scrolling_pane_size": [306, 134]
              }
            }
          ]
        }
      }
    ]
  },

  "collection_browser_grid": {
    "type": "grid",
    "size": ["100%", "default"], // full-width; auto-height
    "grid_item_template": "collect_everything.inventory_slot_button",
    "collection_name": "form_buttons",
    "$item_collection_name": "form_buttons",
    "grid_rescaling_type": "horizontal",
    "maximum_grid_items": 0,
    "bindings": [
      {
        "binding_name": "#form_button_length",
        "binding_name_override": "#length",
        "binding_condition": "once"
      },
      {
        "source_property_name": "(#length)",
        "target_property_name": "#maximum_grid_items",
        "binding_type": "view"
      }
    ]
  },

  "gap": { "type": "panel" }
}
