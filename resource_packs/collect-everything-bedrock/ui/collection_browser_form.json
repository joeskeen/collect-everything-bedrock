{
  "namespace": "collect_everything",
  "title_text": {
    "type": "label",
    "text": "#browser_title",
    "color": "$title_text_color",
    "layer": 2
  },
  "grid_items": {
    "type": "grid",
    "size": ["100%", "default"],
    "grid_dimensions": "$grid_size",
    "grid_item_template": "collect_everything.item_panel",
    "collection_name": "collection_items",
    "layer": 1
  },
  "browser_template": {
    "type": "panel",
    "size": ["100%c", "100%c"],
    "bindings": [
      {
        "binding_name": "#browser_title",
        "binding_type": "global"
      }
    ],
    "controls": [
      {
        "background": {
          "type": "image",
          "texture": "textures/ui/item_background",
          "layer": 0,
          "size": ["100%c + 14px", "100%c + 11px"],
          "controls": [
            {
              "container": {
                "type": "panel",
                "size": ["100%c", "100%c"],
                "controls": [
                  {
                    "stack": {
                      "type": "stack_panel",
                      "orientation": "vertical",
                      "size": ["162px", "100%c"],
                      "controls": [
                        {
                          "gap": {
                            "type": "panel",
                            "size": ["100%", 6]
                          }
                        },
                        {
                          "title@collect_everything.title_text": {}
                        },
                        {
                          "grid@collect_everything.grid_items": {}
                        },
                        {
                          "close_info": {
                            "type": "label",
                            "text": "Click outside to close",
                            "color": "$secondary_text_color",
                            "size": ["100%", 8]
                          }
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      }
    ]
  },
  "browser_panel": {
    "type": "panel",
    "size": ["100%", "100%"],
    "controls": [
      {
        "browser@collect_everything.browser_template": {}
      }
    ]
  },
  "item_panel": {
    "type": "panel",
    "size": [18, 18],
    "layer": 1,
    "controls": [
      {
        "bg": {
          "type": "image",
          "texture": "textures/ui/item_background",
          "size": [18, 18],
          "layer": 0
        }
      },
      {
        "item": {
          "type": "image",
          "size": [16, 16],
          "layer": 1,
          "bindings": [
            {
              "binding_name": "#item_icon",
              "binding_type": "collection",
              "binding_collection_name": "collection_items"
            },
            {
              "binding_name": "#item_aux",
              "binding_type": "collection",
              "binding_collection_name": "collection_items"
            },
            {
              "binding_type": "view",
              "source_property_name": "(not ((#item_icon = '') or (#item_icon = 'loading')))",
              "target_property_name": "#visible"
            }
          ]
        }
      }
    ]
  }
}
