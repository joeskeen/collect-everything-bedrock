{
  "namespace": "collect_everything",

  "inventory_slot_button": {
    "$is_hidden|default": false,
    "type": "panel",
    "size": ["100%c", "100%c"],
    // "ignored": "(#collection_index < $reserved_button_length)",
    // "visible": "((#collection_index > $reserved_button_length or #collection_index = $reserved_button_length) and not #form_button_text = '')",
    "bindings": [
      {
        "binding_name": "#null",
        "binding_type": "collection",
        "binding_condition": "none",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_name": "#null",
        "binding_type": "collection_details",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_name": "#form_button_text",
        "binding_type": "collection",
        "binding_collection_name": "form_buttons"
      }
      // {
      //   "binding_name": "#null",
      //   "binding_type": "view",
      //   "source_property_name": "((#collection_index > $reserved_button_length or #collection_index = $reserved_button_length) and not #form_button_text = '')",
      //   "target_property_name": "#visible"
      // },
      // {
      //   "binding_name": "#null",
      //   "binding_type": "view",
      //   "source_property_name": "(#collection_index < $reserved_button_length)",
      //   "target_property_name": "$is_hidden"
      // }
    ],
    "controls": [{ "@inventory_slot_button_internal": {} }]
  },

  "inventory_slot_button_internal@common.button": {
    "$pressed_button_name": "button.form_button_click",
    "size": ["100%c", "100%c"],
    "bindings": [
      {
        "binding_name": "#null",
        "binding_type": "collection",
        "binding_condition": "none",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_name": "#null",
        "binding_type": "collection_details",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_name": "#form_button_text",
        "binding_type": "collection",
        "binding_collection_name": "form_buttons"
      }
    ],
    "default_control": "inventory_slot_default_view",
    "hover_control": "inventory_slot_hover_view",
    "pressed_control": "inventory_slot_pressed_view",
    "controls": [
      { "inventory_slot_default_view@inventory_cell": {} },
      { "inventory_slot_hover_view@inventory_cell": { "$hover": true } },
      { "inventory_slot_pressed_view@inventory_cell": { "$pressed": true } }
    ]
  },

  "inventory_cell": {
    "type": "panel",
    "size": [18, 18],
    "$hover|default": false,
    "$pressed|default": false,
    "controls": [
      { "item@inventory_item": {} },
      { "background@inventory_cell_background": {} },
      { "highlight@inventory_cell_highlight": { "visible": "($hover or $pressed)" } },
      { "focus_border@inventory_cell_focus_border": { "visible": "($hover or $pressed)" } }
    ]
  },

  "inventory_item": {
    "type": "panel",
    "size": [18, 18],
    "bindings": [
      {
        "binding_name": "#null",
        "binding_type": "collection",
        "binding_condition": "none",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_name": "#null",
        "binding_type": "collection_details",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_name": "#form_button_text",
        "binding_type": "collection",
        "binding_collection_name": "form_buttons"
      }
    ],
    "$aux_id": [
      {
        "binding_name": "#form_button_texture",
        "binding_type": "collection",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_type": "view",
        // if the first 8 bytes of the #form_button_texture string isn't 'textures', show this (numerical id texture)
        "source_property_name": "(not (('%.8s' * #form_button_texture) = 'textures'))",
        "target_property_name": "#visible"
      },
      {
        "binding_type": "view",
        "source_property_name": "(not ((#texture = '') or (#texture = 'loading')))",
        "target_property_name": "#visible"
      },
      {
        "binding_type": "view",
        "source_property_name": "((#form_button_texture - (#form_button_texture % 65536)) / 65536)",
        "target_property_name": "#item_id_aux"
      }
    ],
    "controls": [
      // if texture is a number, it renders via inventory item renderer
      {
        "@beacon.item_renderer": {
          "size": [16, 16],
          "offset": [1, 1],
          "layer": 4,
          "bindings": "$aux_id"
        }
      },
      // if texture is a texture path, it renders as an image
      { "@item_texture": {} },
      { "@inventory_item_amount": {} },
      { "@inventory_item_bar": {} },
      { "@inventory_item_details": { "visible": "$hover" } }
    ]
  },

  "inventory_cell_background": {
    "type": "image",
    "texture": "textures/ui/item_background",
    "size": [18, 18],
    "layer": 2
  },

  "inventory_cell_highlight": {
    "type": "image",
    "size": [18, 18],
    "texture": "textures/ui/highlight_slot",
    "layer": 3
  },

  "inventory_cell_focus_border": {
    "type": "image",
    "size": [18, 18],
    "texture": "textures/ui/focus_border_white",
    "layer": 4
  },

  "inventory_item_bar": {
    "type": "image",
    "texture": "textures/ui/d_b",
    "size": [14, 2],
    "anchor_from": "bottom_middle",
    "anchor_to": "bottom_middle",
    "offset": [0, -1.5],
    "bindings": [
      {
        "binding_type": "collection_details",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_name": "#form_button_text",
        "binding_type": "collection",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_type": "view",
        // detect presence of 'percent' field
        "source_property_name": "(not ((#form_button_text - '|percent|:') = #form_button_text))",
        "target_property_name": "#visible"
      }
    ],
    "controls": [
      {
        "bar": {
          "type": "image",
          "layer": 7,
          "texture": "textures/ui/d_g",
          "size": ["100%", "50%"],
          "offset": [0, -0.5],
          "clip_pixelperfect": false,
          "clip_direction": "left",
          "$clip_max": 99,
          "$one": 1.0,
          "bindings": [
            {
              "binding_type": "collection_details",
              "binding_collection_name": "form_buttons"
            },
            {
              "binding_name": "#form_button_text",
              "binding_type": "collection",
              "binding_collection_name": "form_buttons"
            },
            {
              "binding_type": "view",
              // extract 'percent' field value
              "source_property_name": "(('%.23s' * #form_button_text) - ('%.20s' * #form_button_text)",
              "target_property_name": "#ratio"
            },
            {
              "binding_type": "view",
              "source_property_name": "(#ratio * $one)",
              "target_property_name": "#ratio_1"
            },
            {
              "binding_type": "view",
              // calculate percentage as value between 0 and 1
              "source_property_name": "(($clip_max - #ratio_1) / $clip_max)",
              "target_property_name": "#clip_ratio"
            }
          ]
        }
      }
    ]
  },

  "inventory_item_amount": {
    "type": "panel",
    "controls": [
      {
        "item_amount": {
          "type": "label",
          "offset": [0, 1],
          "shadow": true,
          "text_alignment": "left",
          "color": "$tool_tip_text",
          "text": "",
          "bindings": [
            {
              "binding_name": "#null",
              "binding_type": "collection",
              "binding_condition": "none",
              "binding_collection_name": "form_buttons"
            },
            {
              "binding_name": "#null",
              "binding_type": "collection_details",
              "binding_collection_name": "form_buttons"
            },
            {
              "binding_name": "#form_button_text",
              "binding_type": "collection",
              "binding_collection_name": "form_buttons"
            },
            // {
            //   "binding_name": "#null",
            //   "binding_type": "view",
            //   // detect presence of 'count' field
            //   "source_property_name": "(not ((#form_button_text - '|count|:') = #form_button_text))",
            //   "target_property_name": "#visible"
            // },
            {
              // extract 'count' field value
              "binding_name": "(('§z') + #collection_index)", // "(('%.10s' * #form_button_text) - ('%.8s' * #form_button_text)",
              "binding_name_override": "#text",
              "binding_collection_name": "form_buttons"
            }
          ]
        }
      }
    ]
  },

  "item_texture": {
    "type": "image",
    "size": [16, 16],
    "layer": 4,
    "bindings": [
      {
        "binding_name": "#form_button_texture",
        "binding_name_override": "#texture",
        "binding_type": "collection",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_type": "view",
        "source_property_name": "(not ((#texture = '') or (#texture = 'loading')))",
        "target_property_name": "#visible"
      },
      {
        "binding_type": "view",
        "source_property_name": "(('%.8s' * #texture) = 'textures')",
        "target_property_name": "#visible"
      }
    ]
  },

  "inventory_item_details": {
    "type": "custom",
    "renderer": "hover_text_renderer",
    "allow_clipping": false,
    "layer": 30,
    "bindings": [
      {
        "binding_name": "#form_button_text",
        "binding_type": "collection",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_type": "view",
        "source_property_name": "(#form_button_text - ('%.23s' * #form_button_text))",
        "target_property_name": "#hover_text"
      },
      {
        "binding_type": "collection_details",
        "binding_collection_name": "form_buttons"
      }
    ]
  }
}
