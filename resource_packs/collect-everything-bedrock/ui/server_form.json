{
  "namespace": "server_form",
  "long_form": {
    "type": "panel",
    "controls": [
      {
        "collection_browser_screen@collect_everything.collection_browser_screen": {
          "bindings": [
            // expose the long_form's title text as a variable for children
            { "binding_name": "#title_text", "binding_type": "global" },
            {
              "binding_type": "view",
              // only show this form if the title of the form starts with our special data prefix string
              "source_property_name": "(not ((#title_text - $collect_everything_data_prefix) = #title_text))",
              "target_property_name": "#visible"
            }
          ]
        }
      },
      // if not collection browser, show default form
      {
        "long_form@common_dialogs.main_panel_no_buttons": {
          "$title_panel": "common_dialogs.standard_title_label",
          "$title_size": ["100% - 14px", 10],
          "size": [225, 200],
          "$text_name": "#title_text",
          "$title_text_binding_type": "none",
          "$child_control": "server_form.long_form_panel",
          "layer": 2,
          "bindings": [
            {
              "binding_name": "#title_text"
            },
            {
              "binding_type": "view",
              "source_property_name": "((#title_text - $collect_everything_data_prefix) = #title_text)",
              "target_property_name": "#visible"
            }
          ]
        }
      }
    ]
  }
}
