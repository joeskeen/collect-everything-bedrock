{
  "namespace": "server_form",
  "long_form": {
    "type": "panel",
    "controls": [
      {
        "collection_browser_screen@collect_everything.collection_browser_screen": {
          "bindings": [
            // expose the long_form's title text as a variable for children
            { "binding_name": "#title_text", "binding_type": "global" },
            {
              "binding_type": "view",
              // only show this form if the title of the form starts with our special data prefix string
              "source_property_name": "(not ((#title_text - $collect_everything_data_prefix) = #title_text))",
              "target_property_name": "#visible"
            }
          ]
        }
      }
    ]
  }
}
